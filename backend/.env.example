# Copy to `.env` and adjust. Run commands from the `backend/` directory so this file is loaded.

# PostgreSQL — SQLAlchemy + psycopg v3 (see requirements.txt; not psycopg2-binary).
# From your host machine (uvicorn on localhost):
DATABASE_URL=postgresql+psycopg://pait:pait@localhost:5432/pait
# From another Docker Compose service on the same network, use the DB service hostname `db`:
# DATABASE_URL=postgresql+psycopg://pait:pait@db:5432/pait

APP_ENV=development
SOURCE_FETCH_USER_AGENT=PersonalAIIntelligenceTool/0.1 (+local-dev)

# Reserved for later features (not used by the app yet)
# OPENAI_API_KEY=
# REDIS_URL=

# Resend — digest email delivery (https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM=Sipply <digest@sipply.dev>
